<%# ✗ DON'T: a hotspot with an href but no alt is an unlabeled interactive control.
    The component raises on this — so we can't render it live. The call below is the
    anti-pattern, shown commented; the rendered map is the CORRECT fix (alt supplied).

    ui :map_area,
       src: "https://picsum.photos/id/1018/600/400", alt: "Mountain valley",
       areas: [ { shape: :rect, coords: "0,0,600,400", href: "#peak" } ]  # ← no alt → raises
%>
<%= ui :map_area,
      src: "https://picsum.photos/id/1018/600/400",
      alt: "Mountain valley — one labeled region",
      width: 600, height: 400,
      areas: [
        { shape: :rect, coords: "0,0,600,400", href: "#peak", alt: "Mountain peak" }
      ] %>
