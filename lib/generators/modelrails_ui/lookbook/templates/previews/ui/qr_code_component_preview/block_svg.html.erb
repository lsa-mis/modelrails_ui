<%# Raw inline SVG, as a gem like rqrcode emits via `as_svg(...).html_safe`. The %>
<%# wrapper supplies the accessible name, so the bare <svg> need not carry one. %>
<%= ui :qr_code, alt: "QR code linking to example.com" do %>
  <svg viewBox="0 0 9 9" width="200" height="200" shape-rendering="crispEdges" aria-hidden="true">
    <path fill="currentColor" d="M0 0h3v3H0zM4 0h1v1H4zM6 0h3v3H6zM0 4h1v1H0zM2 4h1v1H2zM4 4h1v1H4zM6 4h1v1H6zM8 4h1v1H8zM0 6h3v3H0zM4 6h1v1H4zM6 6h3v3H6z"/>
  </svg>
<% end %>
