<%= ui :sidebar, brand: "Acme" do |s| %>
  <% s.with_group(label: "Main") do |g| %>
    <% g.with_item(label: "Dashboard", href: "#", icon: :home, active: true) %>
    <% g.with_item(label: "Tasks", href: "#", icon: :tasks) %>
